{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@m-grid/core": ["packages/core/dist/index.d.ts"],
      "@m-grid/dom": ["packages/dom/dist/index.d.ts"],
      "@m-grid/vue": ["packages/vue/dist/index.d.ts"]
    },
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noImplicitOverride": true,
    "useUnknownInCatchVariables": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true
  }
}
