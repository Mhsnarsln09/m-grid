{
  "name": "@m-grid/theme-default",
  "version": "0.1.0",
  "description": "Optional default CSS theme for m-grid.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "mGrid": {
    "offeringPolicy": "Single open-source offering with no Community/Pro separation during the first project year"
  },
  "type": "module",
  "sideEffects": ["**/*.css"],
  "files": ["dist", "src"],
  "exports": {
    "./base.css": "./src/base.css",
    "./light.css": "./src/light.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node -e \"console.log('theme-default: CSS source package')\"",
    "typecheck": "node -e \"console.log('theme-default: no TypeScript sources')\""
  }
}
