{
  "name": "@m-grid/vue",
  "version": "0.1.0",
  "description": "Vue adapter contracts for m-grid.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "mGrid": {
    "offeringPolicy": "Single open-source offering with no Community/Pro separation during the first project year"
  },
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@m-grid/core": "workspace:^",
    "@m-grid/dom": "workspace:^"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
